# Copy this file to .env.test and fill in real test credentials.
# These are used by the Playwright E2E tests only.
# Never commit .env.test — it is gitignored.

# Staging base URL (leave blank to test against localhost:3001)
TEST_BASE_URL=https://womenkind-git-staging-dlolli-2486s-projects.vercel.app

# Vercel deployment protection bypass secret (optional, only needed if protection is enabled)
VERCEL_AUTOMATION_BYPASS_SECRET=your-bypass-secret

# Staging Supabase credentials (for direct API sign-in in Tier 2 tests)
TEST_SUPABASE_URL=https://your-staging-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-staging-anon-key

# Test provider account (staging Supabase)
TEST_PROVIDER_EMAIL=test-provider@womenkind.dev
TEST_PROVIDER_PASSWORD=TestProvider2026!

# Unrelated test patient (no appointment with the test provider)
TEST_UNRELATED_PATIENT_ID=b1000000-0000-0000-0000-000000000001

# Patient journey tests (patient-journey.spec.ts)
# ENABLE_TEST_ROUTES must be set to 'true' on the target Vercel environment (staging only, never prod).
# The debug endpoints /api/debug/verification-url and /api/debug/cleanup-test-patient are gated by this flag.
# Set it on staging: vercel env add ENABLE_TEST_ROUTES preview staging --value 'true' --yes

# Promo code to test on patient 3's Stripe checkout (must exist in Stripe test-mode dashboard).
# Leave blank to skip promo code testing and use a card for all 5 patients.
TEST_PROMO_CODE=FOUNDRY2
